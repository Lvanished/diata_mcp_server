# NCBI — pubmed-mcp-server reads NCBI_ADMIN_EMAIL / NCBI_API_KEY (see server README).
# This project passes NCBI_EMAIL through to the server as NCBI_ADMIN_EMAIL if set.
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=

# MCP client transport: stdio (spawn server) or http (Streamable HTTP).
# On Windows, if you see WinError 2 when starting stdio, either install Bun/Node
# or use HTTP (recommended quick start):
#   MCP_TRANSPORT=http
#   MCP_SERVER_URL=https://pubmed.caseyjhand.com/mcp
MCP_TRANSPORT=stdio

# STDIO: command and args to start pubmed-mcp-server (Bun is what upstream uses).
# After setup_pubmed_mcp.sh, the built server is started with:
MCP_SERVER_COMMAND=bun
MCP_SERVER_ARGS=run,start:stdio
MCP_SERVER_CWD=./pubmed-mcp-server

# Extra env for the child process (semicolon-separated KEY=VAL pairs, optional)
# MCP_SERVER_ENV=MCP_LOG_LEVEL=info;NCBI_REQUEST_DELAY_MS=400

# HTTP: Streamable HTTP endpoint (bun run start:http — default port 3010, path /mcp)
# MCP_TRANSPORT=http
# MCP_SERVER_URL=http://localhost:3010/mcp
# Public hosted instance (testing only; prefer self-host for production):
# MCP_SERVER_URL=https://pubmed.caseyjhand.com/mcp

# Alternative STDIO: run the published package without a local git clone
# MCP_SERVER_COMMAND=npx
# MCP_SERVER_ARGS=-y,@cyanheads/pubmed-mcp-server@latest
# MCP_SERVER_CWD=.
